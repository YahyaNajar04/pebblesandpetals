---
import all from "../data/gallery.json";

const { title = "Gallery",ids, tag, limit } = Astro.props;

let images = all;
if (ids) images = images.filter((img) => ids.includes(img.id));
if (tag) images = images.filter((img) => img.tags?.includes(tag));
if (limit) images = images.slice(0, limit);
---

<section class="mx-auto max-w-6xl px-4 py-20">
    <h2
    class="text-center font-display text-4xl font-bold text-coral md:text-5xl"
  >
    {title}
  </h2>
  <div class="mt-10 flex flex-wrap justify-center gap-6">
    {
      images.map((img) => (
        <img
          src={`/${img.src}`}
          alt={img.alt}
          loading="lazy"
          class="zoomable cursor-pointer h-64 w-full max-w-sm object-cover sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] rounded-2xl border-3 border-ink shadow-[4px_4px_0_var(--color-sky)] transition hover:scale-[1.02]"
        />
      ))
    }
  </div>
</section>
