---
const { href, color = "bg-sunny", class: extra = "" } = Astro.props;
---

<a  href = {href}
      class= {`inline-block rounded-2xl border-3 border-ink ${color} px-6 py-3 font-display text-xl shadow-[4px_4px_0_var(--color=ink)] transition hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0-var(--color-ink)] ${extra}`}
>
      <slot />
</a>