---
import { WHATSAPP, TEL, site } from "../lib/site";
---
<footer class="mt-16 bg-ink px-4 py-12 text-cream">
  <div class="mx-auto grid max-w-5xl gap-8 text-center md:grid-cols-3 md:text-left">
    <div>
      <h3 class="font-display text-xl text-sunny">Pebbles and Petals Pre-School</h3>
      <p class="mt-2">{site.address}</p>
      <p>{site.hours}</p>
    </div>
    <div>
      <h3 class="font-display text-xl text-coral">Get in Touch</h3>
      <p class="mt-2"><a href={WHATSAPP} class="text-grass">💬 Chat on WhatsApp</a></p>
      <p><a href={TEL} class="text-sky">📞 {site.phone}</a></p>
    </div>
    <div class="flex justify-center md:justify-start">
      <div class="rounded-xl border-2 border-dashed border-cream/40 p-3 text-xs text-cream/60">
        <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d486.23270341196303!2d75.7653453405486!3d33.314704051603066!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e1!3m2!1sen!2sin!4v1784710327136!5m2!1sen!2sin" width="330" height="200" style="border:2;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
      </div>
    </div>
  </div>
  <p class="mt-10 text-center text-sm text-cream/60">© 2026 Pebbles and Petals Pre-School. Est. 2025.</p>
</footer>