---
import facilities from "../data/facilities.json";
---

<section class="px-4 py-20">
  <div class="mx-auto flex max-w-5xl flex-wrap justify-center gap-10">
    {
      facilities.map((f) => (
        <div
          data-zoom-src={`/${f.img}`}
          data-zoom-alt={f.label}
          class="flex w-32 cursor-pointer flex-col items-center gap-3 text-center transition hover:scale-105"
        >
          <div
            class={`flex h-24 w-24 items-center justify-center rounded-full border-3 border-ink text-4xl ${f.bg}`}
          >
            {f.emoji}
          </div>
          <span class="font-display">{f.label}</span>
        </div>
      ))
    }
  </div>
</section>
