---
import team from "../data/team.json";
---
<section class="mx-auto max-w-6xl px-4 py-16">
  <h2 class="text-center font-display text-4xl font-bold text-coral md:text-5xl">Meet Our Team</h2>
  <p class="mt-2 text-center">The caring faces behind Pebbles & Petals.</p>

  <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {team.map((member, i) => (
      <div class="rounded-2xl border-3 border-ink bg-white p-6 text-center"
           style={`box-shadow: 5px 5px 0 var(--color-${["sunny","sky","coral","grass"][i % 4]})`}>
        {member.photo
          ? <img src={`/team/${member.photo}`} alt={member.name} class="mx-auto h-24 w-24 rounded-full border-3 border-ink object-cover" />
          : <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full border-3 border-ink bg-sunny/30 text-4xl">👩‍🏫</div>}
        <h3 class="mt-3 font-display text-lg">{member.name}</h3>
        <p class="text-sm text-sky font-display">{member.role}</p>
        <p class="mt-2 text-xs text-ink/70">{member.bio}</p>
      </div>
    ))}
  </div>
</section>