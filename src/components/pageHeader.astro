---
const { title, subtitle, bg = "bg-sky" } = Astro.props;
---
<section class={`${bg} px-4 py-16 text-center text-white`}>
  <h1 class="font-display text-5xl font-bold md:text-6xl [text-shadow:3px_3px_0_rgba(0,0,0,0.15)]">
    {title}
  </h1>
  {subtitle && (
    <p class="mt-3 text-lg">{subtitle}</p>
  )}
</section>