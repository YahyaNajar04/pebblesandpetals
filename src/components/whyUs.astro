---
import Card from "./card.astro";

const items = [
  { emoji: "🛡️", title: "Safety First", color: "text-coral", shadow: "var(--color-sunny)",
    text: "CCTV in every classroom, secure ID-checked entry, plus an on-call child psychologist." },
  { emoji: "📚", title: "UK-Based Curriculum", color: "text-sky", shadow: "var(--color-sky)",
    text: "Play-based learning packed with curiosity and confidence." },
  { emoji: "🏊", title: "Epic Facilities", color: "text-grass", shadow: "var(--color-coral)",
    text: "Swimming pool, go-karting track, sand & clay pits, sensory play zone." },
  { emoji: "📱", title: "Parent Portal", color: "text-coral", shadow: "var(--color-grass)",
    text: "Live updates, attendance, photos & progress — right on your phone." },
  { emoji: "🧩", title: "Montessori Tools", color: "text-sky", shadow: "var(--color-sunny)",
    text: "Hands-on materials that build little motor skills & big ideas." },
  { emoji: "🍎", title: "Yummy, Healthy Meals", color: "text-grass", shadow: "var(--color-grass)",
    text: "Nutritious, child-friendly menus made fresh daily." },
];
---
<section class="py-16 overflow-hidden">
  <h2 class="text-center font-display text-4xl font-bold text-coral md:text-5xl">
    Why Kids Love It Here!
  </h2>

  <div class="marquee mt-10">
    <div class="marquee-track">
      {[...items, ...items].map((item) => (
        <Card shadow={item.shadow} class="w-64 shrink-0">
          <div class="text-4xl">{item.emoji}</div>
          <h3 class={`mt-3 font-display text-xl ${item.color}`}>{item.title}</h3>
          <p class="mt-2 text-sm">{item.text}</p>
        </Card>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee {
    overflow: hidden;
    /* soft fade at the edges */
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  .marquee-track {
    display: flex;
    gap: 1.5rem;
    width: max-content;
    animation: scroll 30s linear infinite;
  }
  .marquee:hover .marquee-track {
    animation-play-state: paused; /* let parents actually read */
  }
  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-50% - 0.75rem)); }
  }
</style>