---
import PhotoSpot from "./photoSpot.astro";
import about from "../data/about.json";
import Gallery from "./gallery.astro";
---

<section class="px-4 py-16">
  <div class="mx-auto grid max-w-6xl items-center gap-10 md:grid-cols-2">
    <div>
      <h2 class="font-display text-4xl font-bold text-coral md:text-5xl">
        Our Story
      </h2>
      <p class="mt-2 font-display text-lg text-sky">{about.storyTagline}</p>
      <p class="mt-4 leading-relaxed">{about.storyText}</p>
      <div class="mt-6 grid gap-x-6 gap-y-4 sm:grid-cols-2">
        {
          about.storyPoints.map((p) => (
            <p class="flex items-start gap-2">
              <span>{p.emoji}</span> {p.text}
            </p>
          ))
        }
      </div>
    </div>
    <img
      src="/Home_Image1.jpeg"
      alt="Our colourful campus at Pebbles & Petals"
      class="h-72 w-full rounded-2xl border-3 border-ink object-cover shadow-[6px_6px_0_var(--color-sky)]"
    />
  </div>
</section>
