---
import schedule from "../data/schedule.json";
---
<section class = "px-4 py-8">
      <div class = "mx-auto max-w-6xl rounded-3xl border-3 border-ink bg-coral p-8 md:p-12">
            <h2 class = "text-center font-display text-4xl font-bold text-white [text-shadow:2px_2px_0_rgba(0,0,0,0.15)]">
                  A Day at Pebbles & Petals
            </h2>
            <div class = "mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
                  {schedule.map((s) => (
                        <div class = "rounded-2xl border-3 border-ink bg-white p-4 text-center">
                        <p class = "font-display text-xl text-coral">{s.time}</p>
                        <p class = "text-2xl">{s.emoji}</p>
                        <p class = "mt-1 text-sm">{s.label}</p>
                        </div>
                  ))}
            </div>
      </div>
</section>