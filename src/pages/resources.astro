---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/pageHeader.astro";
import Card from "../components/card.astro";
import activities from "../data/activities.json";
import schedule from "../data/schedule.json";
import specialDays from "../data/specialDays.json";
import core from "../data/coreFacilities.json";

const nav = [
  { id: "activities", label: "Activity Planner" },
  { id: "schedule", label: "Daily Schedule" },
  { id: "facilities", label: "Core Facilities" },
];
---

<Base title="Resources | Pebbles and Petals Pre-School">
  <PageHeader
    title="Resources"
    subtitle="Everything you need to know about a day with us"
    bg="bg-grass"
  />

  <!-- Anchor nav -->
  <nav
    class="sticky top-[105px] z-40 border-b-3 border-sunny bg-cream/95 backdrop-blur"
  >
    <div
      class="mx-auto flex max-w-4xl flex-wrap justify-center gap-4 px-4 py-3 font-display"
    >
      {
        nav.map((n) => (
          <a
            href={`#${n.id}`}
            class="rounded-full px-3 py-1 hover:bg-coral/10 hover:text-coral"
          >
            {n.label}
          </a>
        ))
      }
    </div>
  </nav>

  <!-- Activity Planner -->
  <section id="activities" class="scroll-mt-32 bg-sunny/15 px-4 py-14">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center font-display text-4xl font-bold text-coral">
        Activity Planner
      </h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {
          activities.map((cat) => (
            <Card shadow={cat.shadow} class="text-left">
              <h3 class="font-display text-2xl text-sky">
                {cat.emoji} {cat.title}
              </h3>
              <div class="mt-3 space-y-2">
                {cat.items.map((it) => (
                  <p class="text-sm">
                    <strong class="font-display">{it.name}</strong> — {it.desc}
                  </p>
                ))}
              </div>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Daily Schedule -->
  <section id="schedule" class="mx-auto max-w-6xl scroll-mt-32 px-4 py-14">
    <h2 class="text-center font-display text-4xl font-bold text-coral">
      Daily Schedule
    </h2>
    <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
      {
        schedule.map((s) => (
          <div class="rounded-2xl border-3 border-ink bg-white p-4 text-center">
            <p class="font-display text-lg text-coral">{s.time}</p>
            <p class="text-2xl">{s.emoji}</p>
            <p class="mt-1 text-xs">{s.label}</p>
          </div>
        ))
      }
    </div>

    <h3 class="mt-12 text-center font-display text-2xl text-sky">
      Monthly Special Days
    </h3>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      {
        specialDays.map((d) => (
          <div class="rounded-2xl border-3 border-ink bg-white px-4 py-3 text-center text-sm shadow-[4px_4px_0_var(--color-sunny)]">
            <p class="font-display text-coral">{d.when}</p>
            <p>{d.what}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Core Facilities -->
  <section id="facilities" class="scroll-mt-32 bg-sky/10 px-4 py-14">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center font-display text-4xl font-bold text-coral">
        Core Facilities
      </h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          core.map((f, i) => (
            <div
              data-zoom-src={`/${f.img}`}
              data-zoom-alt={f.title}
              class="cursor-pointer transition hover:-translate-y-1"
            >
              <Card
                shadow={
                  [
                    "var(--color-sunny)",
                    "var(--color-sky)",
                    "var(--color-coral)",
                    "var(--color-grass)",
                  ][i % 4]
                }
              >
                <div class="text-4xl">{f.emoji}</div>
                <h3 class="mt-2 font-display text-lg text-sky">{f.title}</h3>
                <p class="mt-1 text-xs text-ink/70">{f.desc}</p>
              </Card>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
