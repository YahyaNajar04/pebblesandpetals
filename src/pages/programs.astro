---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/pageHeader.astro";
import Programs from "../components/programs.astro";
import DayTimeline from "../components/dayTimeLine.astro";
import themes from "../data/themes.json";
---
<Base title="Programs | Pebbles and Petals Pre-School">
  <PageHeader title="Our Programs" subtitle="From first steps to school-ready" bg="bg-sky" />

  <Programs />

  <!-- Weekly themes -->
  <section class="mx-auto max-w-5xl px-4 py-12">
  <h2 class="text-center font-display text-4xl font-bold text-coral">Weekly Theme Focus</h2>
  <div class="mt-8 overflow-x-auto">
    <div class="overflow-hidden rounded-2xl border-3 border-ink shadow-[6px_6px_0_var(--color-sky)]">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="bg-sky font-display text-white">
            <th class="p-4 text-left">Day</th>
            <th class="p-4 text-left">Theme</th>
            <th class="p-4 text-left">Activity</th>
            <th class="p-4 text-left">Art / Music</th>
          </tr>
        </thead>
        <tbody>
          {themes.map((t, i) => (
            <tr class={i % 2 ? "bg-sunny/10" : "bg-white"}>
              <td class="p-4 font-display text-sky">{t.day}</td>
              <td class="p-4">{t.theme}</td>
              <td class="p-4">{t.activity}</td>
              <td class="p-4">{t.art}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

  <DayTimeline />
</Base>