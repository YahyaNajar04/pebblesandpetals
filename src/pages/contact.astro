---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/pageHeader.astro";
import Button from "../components/button.astro";
import { WHATSAPP, TEL, waLink, site } from "../lib/site";
---
<Base title="Contact | Pebbles and Petals Pre-School">
  <PageHeader title="Get in Touch" subtitle="We'd love to hear from you" bg="bg-grass" />

  <main class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-8 md:grid-cols-2">
      <!-- Details -->
      <div class="rounded-2xl border-3 border-ink bg-white p-8 shadow-[6px_6px_0_var(--color-sunny)]">
        <h2 class="font-display text-2xl text-coral">Pebbles &amp; Petals Pre-School</h2>
        <p class="mt-4">📍 {site.address}</p>
        <p class="mt-2">🕘 {site.hours}</p>
        <p class="mt-2">📞 <a href={TEL} class="text-sky">{site.phone}</a></p>

        <div class="mt-6 flex flex-wrap gap-4">
          <Button href={waLink("Hi! I'd like to enquire about admission.")} color="bg-grass" class="text-white">💬 WhatsApp Us</Button>
          <Button href={TEL}>📞 Call Now</Button>
        </div>
      </div>

      <!-- Map -->
      <div class="overflow-hidden rounded-2xl border-3 border-ink shadow-[6px_6px_0_var(--color-sky)]">
        <iframe
          title="Pebbles & Petals location"
          src="https://www.google.com/maps?q=Heritage+Bagh,+Kishtwar&output=embed"
          class="h-full min-h-[320px] w-full"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </main>
</Base>